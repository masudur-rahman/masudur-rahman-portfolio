---
import { siteConfig } from "../config";
import { marked } from "marked";
const gallery = siteConfig.gallery ?? [];
function renderMarkdown(md) {
  const rawHTML = marked.parse(md || "");
  // force all <a> to open in new tab
  return rawHTML.replace(/<a ([^>]+)>/g, '<a $1 target="_blank" rel="noopener noreferrer">');
}
---
<section id="gallery" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">Photo Gallery</h2>
        <div class="w-[75px] h-[5px] mt-2 rounded-full" style={`background-color: #1d4ed8`} />
        <p class="text-gray-600 mt-4">Click a photo to view details.</p>
      </div>
      <div class="lg:col-span-8">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {gallery.map((item, idx) => (
            <button type="button" class="focus:outline-none gallery-trigger" data-modal={idx}>
              <div class="relative w-full aspect-[1.3/1]">
                <img src={item.image} alt={item.image} class="rounded-lg w-full h-full object-cover hover:shadow-xl transition-shadow duration-300 cursor-pointer" loading="lazy" />
                {/* Overlay title/date bar */}
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-3 py-2 flex justify-between items-center rounded-b-lg pointer-events-none">
                  <span class="text-white text-xs sm:text-sm font-semibold truncate max-w-[70%]">{item.title ?? "Untitled"}</span>
                  <span class="text-white text-xs sm:text-xs font-normal ml-3 opacity-80">{item.date ?? ""}</span>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>

    {/* Modals */}
    {gallery.map((item, idx) => (
      <div id={`gallery-modal-${idx}`} class="gallery-modal hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60" tabindex="-1" data-modal-index={idx}>
        <div class="bg-white rounded-xl max-w-lg w-full p-4 relative gallery-modal-content">
          <button type="button" class="absolute top-2 right-3 text-2xl text-gray-500 p-2 hover:text-gray-800 gallery-close" aria-label="Close">&times;</button>
          <img src={item.image} alt="Gallery" class="w-full rounded-lg mb-4" />
          <div class="text-gray-900 text-lg font-semibold mb-2">{item.title ?? "Untitled"}</div>
          <div class="text-gray-500 text-xs mb-3">{item.date ?? ""}</div>
          <div class="text-gray-700 text-base whitespace-pre-line prose prose-blue max-w-none markdown-content" set:html={renderMarkdown(item.description)}></div>
        </div>
      </div>
    ))}
  </div>
  <script>
    // Vanilla JS for all modal triggers on the page
    document.addEventListener('DOMContentLoaded', function() {
      const modals = document.querySelectorAll('.gallery-modal');
      const triggers = document.querySelectorAll('.gallery-trigger');
      triggers.forEach(btn => {
        btn.addEventListener('click', function() {
          const idx = btn.getAttribute('data-modal');
          const modal = document.getElementById('gallery-modal-' + idx);
          if (modal) modal.classList.remove('hidden');
        });
      });
      modals.forEach(modal => {
        modal.addEventListener('click', function(e) {
          if (!e.target.closest('.gallery-modal-content')) {
            modal.classList.add('hidden');
          }
        });
        const closeBtn = modal.querySelector('.gallery-close');
        if (closeBtn) {
          closeBtn.addEventListener('click', function() {
            modal.classList.add('hidden');
          });
        }
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' || e.key === 'Esc') {
          modals.forEach(modal => modal.classList.add('hidden'));
        }
      });
    });
  </script>
</section>
 