---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
const achievements = siteConfig.achievements ?? [];
---
{achievements.length > 0 && (
  <section id="achievements" class="p-8 sm:p-12 md:p-16 lg:p-24" aria-label="Notable Feats" role="region">
    <div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
        <div class="lg:col-span-4">
          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-[var(--color-text-section-title)]">
            Notable Feats
          </h2>
          <div class="w-[75px] h-[5px] mt-2 rounded-full accent-bg-color" />
        </div>
        <div class="lg:col-span-8">
          <div class="space-y-6">
            {achievements.map((item) => (
              <div class="bg-bg-light dark:bg-bg-dark rounded-lg shadow-sm border border-gray-100 dark:border-gray-800 p-4 sm:p-6 flex items-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <span class="inline-block w-2 h-2 rounded-full bg-primary mr-4 flex-shrink-0"></span>
                <span class="text-base sm:text-lg text-[var(--color-text-body)] markdown-content" set:html={renderMarkdown(item)}></span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
</style>
