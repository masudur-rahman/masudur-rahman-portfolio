---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---
{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24" aria-label="Education" role="region">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-[var(--color-text-section-title)]">
              Education
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full accent-bg-color"
            />
          </div>
          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.education.map((edu) => (
                <div class="bg-bg-light dark:bg-bg-dark rounded-lg shadow-sm border border-gray-100 dark:border-gray-800 p-4 sm:p-5 md:p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                      <h3 class="text-lg sm:text-xl font-semibold text-[var(--color-text-card-title)] markdown-content" set:html={renderMarkdown(edu.degree)}></h3>
                      <div class="text-base sm:text-lg text-[var(--color-text-card-subtitle)] markdown-content edu-school-link" set:html={renderMarkdown(edu.school)}></div>
                    </div>
                    <span class="text-xs sm:text-sm text-[var(--color-text-muted)] mt-2 sm:mt-0">
                      {edu.dateRange}
                    </span>
                  </div>
                  <ul class="space-y-3">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 dark:bg-gray-600 mt-2 mr-3 flex-shrink-0" />
                        <span class="text-sm sm:text-base text-[var(--color-text-body)] markdown-content" set:html={renderMarkdown(achievement)}></span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
</style>
