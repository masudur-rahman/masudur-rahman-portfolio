---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
import SectionLayout from "./SectionLayout.astro";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---
{hasExperience && 
  <SectionLayout title="Experience">
    <div slot="content">
      <div class="relative">
        {siteConfig.experience.map((exp, index) => (
          <div class="relative mb-12 last:mb-0">
            {/* Timeline dot at top of card */}
            <div
              class="absolute left-1/2 -top-2 w-4 h-4 bg-bg-light dark:bg-bg-dark border-2 rounded-full -translate-x-1/2 z-20 transition-all duration-300 timeline-dot"
            />
            {/* Connecting line below card */}
            {index < siteConfig.experience.length - 1 && (
              <div class="absolute left-1/2 bottom-0 w-0.5 h-12 bg-gray-300 dark:bg-gray-700 -translate-x-1/2 translate-y-full z-10" />
            )}
            {/* Experience card */}
            <div class="bg-bg-light dark:bg-bg-dark rounded-lg shadow-sm border border-gray-100 dark:border-gray-800 p-4 sm:p-5 md:p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
                <div>
                  <h3 class="text-lg sm:text-xl font-semibold text-[var(--color-text-card-title)] markdown-content" set:html={renderMarkdown(exp.title)}></h3>
                  <div class="text-base sm:text-lg text-[var(--color-text-card-subtitle)] markdown-content exp-company-link company-link" set:html={renderMarkdown(exp.company)}></div>
                </div>
                <span class="text-xs sm:text-sm text-[var(--color-text-muted)] mt-2 sm:mt-0">
                  {exp.dateRange}
                </span>
              </div>
              <ul class="space-y-2">
                {exp.bullets.map((bullet) => (
                  <li>
                    <div class="flex items-start">
                      <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 dark:bg-gray-600 mt-2 mr-3 flex-shrink-0" />
                      <span class="text-sm sm:text-base text-[var(--color-text-body)] markdown-content" set:html={renderMarkdown(typeof bullet === 'string' ? bullet : bullet.text)}></span>
                    </div>
                    {typeof bullet !== 'string' && bullet.tools && (
                      <div class="flex flex-wrap gap-2 mt-2 ml-6">
                        <span class="text-sm font-semibold">Tools:</span>
                        {bullet.tools.map((tool) => (
                          <span class="px-2 py-1 bg-[var(--color-bg-tag)] text-[var(--color-text-tag)] rounded-md text-xs font-medium">
                            {tool}
                          </span>
                        ))}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </SectionLayout>
}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
  .timeline-dot {
    border-color: var(--accentColor);
    background-color: var(--accentColor);
  }
  .company-link {
    border-left: 3px solid var(--accentColor);
    padding-left: 0.75rem;
    margin-top: 0.125rem;
    margin-bottom: 0.125rem;
  }
</style>
