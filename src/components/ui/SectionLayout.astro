---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="p-6 sm:p-10 md:p-14 lg:p-24">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
    <div class="lg:col-span-4 lg:sticky self-start top-24">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-4xl xl:text-6xl font-bold text-[var(--color-text-section-title)]"
      >
        {title}
      </h2>
      <div
        class="w-[75px] h-[5px] mt-2 rounded-full accent-bg-color"
      >
      </div>
    </div>
    <div class="lg:col-span-8">
      <slot name="content" />
    </div>
  </div>
</section>

<style>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
</style>
