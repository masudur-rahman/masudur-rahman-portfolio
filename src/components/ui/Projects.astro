---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
import Icon from "../Icon.astro";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasFilters = siteConfig.projectFilters && siteConfig.projectFilters.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-bg-light dark:bg-bg-dark" aria-label="Projects" role="region">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-[var(--color-text-section-title)]">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full accent-bg-color"
            />
          </div>

          <div class="lg:col-span-8">
            {/* Filter Buttons */}
            {hasFilters && (
              <div class="mb-8">
                <div class="flex flex-wrap gap-2 sm:gap-3">
                  {siteConfig.projectFilters.map((filter) => (
                    <button
                      class={`filter-button px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 ${
                        filter.filter === "all" ? "selected" : ""
                      }`}
                      data-filter={filter.filter}
                    >
                      <span class="markdown-content" set:html={renderMarkdown(filter.name)}></span>
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* Projects Grid */}
            <div class="space-y-8" id="projects-container">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div 
                    class="project-item group relative" 
                    data-category={project.category || "all"}
                  >
                    <Component
                      {...linkProps}
                      class={`block relative p-4 sm:p-6 md:p-8 bg-bg-light dark:bg-bg-dark rounded-xl sm:rounded-2xl border border-gray-200 dark:border-gray-700 transition-all duration-300 ${
                        project.link
                          ? "hover:shadow-lg hover:-translate-y-1"
                          : ""
                      }`}
                    >
                      {project.link && (
                        <div class="absolute top-4 right-4 sm:top-6 sm:right-6 md:top-8 md:right-8 w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 flex items-center justify-center bg-gray-900 rounded-full text-white transition-all duration-300 group-hover:bg-gray-700">
                          <svg
                            class="w-4 h-4 sm:w-4.5 sm:h-4.5 md:w-5 md:h-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-4">
                        <div>
                          <div class="flex items-center gap-2 mb-2">
                            <span
                              class="text-sm font-mono accent-text-color"
                            >
                              0{index + 1}
                            </span>
                            {project.role && (
                              <span class="text-xs px-2 py-1 bg-[var(--color-bg-role)] text-[var(--color-text-role)] rounded-full font-medium">
                                {project.role}
                              </span>
                            )}
                            {project.category && (
                              <span class="text-xs px-2 py-1 bg-[var(--color-bg-tag)] text-[var(--color-text-tag)] rounded-full font-medium">
                                {project.category.replace('-', ' ')}
                              </span>
                            )}
                          </div>
                          <h3 class="text-xl sm:text-2xl font-bold text-[var(--color-text-card-title)] markdown-content" set:html={renderMarkdown(project.name)}></h3>
                          {project.timeline && (
                            <p class="text-sm text-[var(--color-text-muted)] mt-1 markdown-content" set:html={renderMarkdown(project.timeline)}></p>
                          )}
                        </div>

                        <div
                          class={`text-base sm:text-lg text-[var(--color-text-body)] leading-relaxed markdown-content ${project.link ? "pr-12 sm:pr-14 md:pr-16" : ""}`}
                          set:html={renderMarkdown(project.description)}
                        ></div>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                            {project.skills.map((skill) => (
                              <span
                                class={`px-2.5 sm:px-3 py-1 sm:py-1.5 bg-[var(--color-bg-tag)] text-[var(--color-text-tag)] rounded-md sm:rounded-lg text-xs sm:text-sm font-medium transition-all duration-300 ${
                                  project.link ? "group-hover:bg-gray-200 dark:group-hover:bg-gray-700" : ""
                                }`}
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      {/* JavaScript for filtering */}
      <script src="../../scripts/projects.js"></script>
    </section>
  )
}

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
  .accent-text-color {
    color: var(--accentColor);
  }
</style>
