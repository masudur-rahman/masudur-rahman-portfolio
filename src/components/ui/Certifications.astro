---
import { siteConfig } from "../../config";
import SectionLayout from "./SectionLayout.astro";
---

<SectionLayout title="Credentials">
  <div slot="content">
    <div class="space-y-8">
      {siteConfig.certifications.map((cert) => (
        <div class="bg-bg-light dark:bg-bg-dark rounded-lg shadow-sm border border-gray-100 dark:border-gray-800 p-4 sm:p-5 md:p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-4">
            {cert.logo && <img src={cert.logo} alt={cert.issuer} class="w-12 h-12" />}
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-[var(--color-text-card-title)]">{cert.name}</h3>
              <p class="text-base sm:text-lg text-[var(--color-text-card-subtitle)]">{cert.issuer}</p>
              <p class="text-sm text-[var(--color-text-muted)] mt-1">
                Issued {cert.issueDate}
                {cert.expirationDate && ` · Expires ${cert.expirationDate}`}
              </p>
              {cert.credentialId && <p class="text-sm text-[var(--color-text-muted)] mt-1">Credential ID {cert.credentialId}</p>}
              <a href={cert.credentialUrl} target="_blank" rel="noopener noreferrer" class="inline-block mt-4 px-4 py-2 bg-gray-100 dark:bg-gray-800 text-sm font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors duration-200">
                Show credential
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</SectionLayout>
