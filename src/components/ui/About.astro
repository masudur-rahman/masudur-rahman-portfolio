---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
---
<section id="about" class="p-8 sm:p-12 md:p-16 lg:p-24" aria-label="About Me" role="region">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2
          class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-[var(--color-text-section-title)]"
        >
          About Me
        </h2>
        <div
          class="w-[75px] h-[5px] mt-2 rounded-full accent-bg-color"
        >
        </div>
      </div>
      <div class="lg:col-span-8 space-y-8">
        <div class="text-lg sm:text-xl md:text-2xl leading-relaxed text-[var(--color-text-body)] prose max-w-none markdown-content" set:html={renderMarkdown(siteConfig.aboutMe)}></div>
        <div class="pt-4">
          <div class="flex flex-wrap gap-3">
            {
              siteConfig.skills.map((skill) => (
                <span class="px-3 sm:px-4 py-1.5 sm:py-2 bg-[var(--color-bg-tag)] text-[var(--color-text-tag)] rounded-full text-sm sm:text-base md:text-lg font-medium hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors duration-200">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
</style>

