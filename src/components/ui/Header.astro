---
import { siteConfig } from "../../config";
import Navigation from "./Navigation.astro";
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center">
        <a href="#hero" class="text-2xl font-bold accent-text-color">
          {siteConfig.name}
        </a>
      </div>
      <div class="hidden md:block">
        <nav class="ml-10 flex items-baseline space-x-4">
          <Navigation />
        </nav>
      </div>
      <div class="-mr-2 flex md:hidden">
        <button type="button" id="hamburger-button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-white" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="hidden md:hidden" id="mobile-menu">
    <nav class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white/90 backdrop-blur-sm">
      <Navigation isMobile={true} />
	</nav>
  </div>
</header>

<script src="../../scripts/header.js"></script>

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-text-color {
    color: var(--accentColor);
  }
  html {
    scroll-behavior: smooth;
  }
</style>
