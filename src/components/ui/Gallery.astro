---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
import SectionLayout from "./SectionLayout.astro";
const gallery = siteConfig.gallery ?? [];
---
<SectionLayout title="Photo Gallery">
  <div slot="content">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {gallery.map((item, idx) => (
        <button type="button" class="focus:outline-none gallery-trigger" data-modal={idx}>
          <div class="relative w-full aspect-[1.3/1]">
            <img src={item.image} alt={item.title} class="rounded-lg w-full h-full object-cover hover:shadow-xl transition-shadow duration-300 cursor-pointer" loading="lazy" />
            {/* Overlay title/date bar */}
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-3 py-2 flex justify-between items-center rounded-b-lg pointer-events-none">
              <span class="text-white text-xs sm:text-sm font-semibold truncate max-w-[70%]">{item.title ?? "Untitled"}</span>
              <span class="text-white text-xs sm:text-xs font-normal ml-3 opacity-80">{item.date ?? ""}</span>
            </div>
          </div>
        </button>
      ))}
    </div>

    {/* Modals */}
    {gallery.map((item, idx) => (
      <div id={`gallery-modal-${idx}`} class="gallery-modal hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/60" tabindex="-1" data-modal-index={idx}>
        <div class="bg-bg-light dark:bg-bg-dark rounded-xl max-w-3xl w-11/12 md:w-3/4 max-h-[90vh] overflow-y-auto p-4 relative gallery-modal-content">
          <button type="button" class="absolute top-2 right-3 text-3xl text-[var(--color-text-muted)] p-2 hover:text-gray-800 dark:hover:text-gray-200 gallery-close" aria-label="Close">&times;</button>
          <img src={item.image} alt={item.title} class="w-full rounded-lg mb-4" />
          <div class="text-[var(--color-text-card-title)] text-lg font-semibold mb-2">{item.title ?? "Untitled"}</div>
          <div class="text-[var(--color-text-muted)] text-xs mb-3">{item.date ?? ""}</div>
          <div class="text-[var(--color-text-body)] text-base whitespace-pre-line prose prose-blue max-w-none markdown-content" set:html={renderMarkdown(item.description)}></div>

          <!-- Navigation Buttons -->
          <button type="button" class="absolute top-1/2 left-4 transform -translate-y-1/2 bg-black/30 text-white p-3 rounded-full hover:bg-black/50 focus:outline-none gallery-prev">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button type="button" class="absolute top-1/2 right-4 transform -translate-y-1/2 bg-black/30 text-white p-3 rounded-full hover:bg-black/50 focus:outline-none gallery-next">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>
    ))}
    <script src="../../scripts/gallery.js"></script>
  </div>
</SectionLayout>

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
</style>