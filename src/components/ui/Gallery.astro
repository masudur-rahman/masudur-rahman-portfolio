---
import { siteConfig } from "../../config";
import { renderMarkdown } from "../../utils";
const gallery = siteConfig.gallery ?? [];
---
<section id="gallery" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-bg-light dark:bg-bg-dark" aria-label="Photo Gallery" role="region">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-[var(--color-text-section-title)]">Photo Gallery</h2>
        <div class="w-[75px] h-[5px] mt-2 rounded-full accent-bg-color" />
        <p class="text-[var(--color-text-body)] mt-4">Click a photo to view details.</p>
      </div>
      <div class="lg:col-span-8">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {gallery.map((item, idx) => (
            <button type="button" class="focus:outline-none gallery-trigger" data-modal={idx}>
              <div class="relative w-full aspect-[1.3/1]">
                <img src={item.image} alt={item.title} class="rounded-lg w-full h-full object-cover hover:shadow-xl transition-shadow duration-300 cursor-pointer" loading="lazy" />
                {/* Overlay title/date bar */}
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-3 py-2 flex justify-between items-center rounded-b-lg pointer-events-none">
                  <span class="text-white text-xs sm:text-sm font-semibold truncate max-w-[70%]">{item.title ?? "Untitled"}</span>
                  <span class="text-white text-xs sm:text-xs font-normal ml-3 opacity-80">{item.date ?? ""}</span>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>

    {/* Modals */}
    {gallery.map((item, idx) => (
      <div id={`gallery-modal-${idx}`} class="gallery-modal hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60" tabindex="-1" data-modal-index={idx}>
        <div class="bg-bg-light dark:bg-bg-dark rounded-xl max-w-lg w-full p-4 relative gallery-modal-content">
          <button type="button" class="absolute top-2 right-3 text-2xl text-[var(--color-text-muted)] p-2 hover:text-gray-800 dark:hover:text-gray-200 gallery-close" aria-label="Close">&times;</button>
          <img src={item.image} alt={item.title} class="w-full rounded-lg mb-4" />
          <div class="text-[var(--color-text-card-title)] text-lg font-semibold mb-2">{item.title ?? "Untitled"}</div>
          <div class="text-[var(--color-text-muted)] text-xs mb-3">{item.date ?? ""}</div>
          <div class="text-[var(--color-text-body)] text-base whitespace-pre-line prose prose-blue max-w-none markdown-content" set:html={renderMarkdown(item.description)}></div>
        </div>
      </div>
    ))}
  </div>
  <script src="../../scripts/gallery.js"></script>
</section>

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-bg-color {
    background-color: var(--accentColor);
  }
</style>