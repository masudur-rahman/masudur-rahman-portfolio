---
import { siteConfig } from "../../config";
import Icon from "../Icon.astro";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasOpenSource = siteConfig.openSourceProjects && siteConfig.openSourceProjects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<footer class="relative bg-bg-light dark:bg-bg-dark border-t border-gray-200 dark:border-gray-800 z-40">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between gap-8"
    >
      <div class="flex flex-col gap-4">
        <h3 class="text-2xl font-bold text-[var(--color-text-section-title)]">
          {siteConfig.name}
        </h3>
        <p class="text-base text-[var(--color-text-body)]">
          {siteConfig.title}
        </p>
        <div class="flex gap-x-6">
          {siteConfig.social.map((social) => (
            <a
              href={social.url}
              aria-label={social.name}
              target={social.name !== 'Email' ? '_blank' : undefined}
              rel={social.name !== 'Email' ? 'noopener noreferrer' : undefined}
              class="text-[var(--color-text-muted)] transition-colors duration-300 hover:text-[var(--accent-color)] accent-color"
            >
              <Icon name={social.name.toLowerCase()} className="h-6 w-6" />
            </a>
          ))}
        </div>
      </div>

      <div class="hidden md:block flex flex-col md:items-end gap-4">
        <nav class="flex gap-x-8">
          <a
            href="#about"
            class="text-sm text-[var(--color-text-muted)] hover:text-text-light dark:hover:text-text-dark transition-colors"
            >About</a
          >
          {
            hasProjects && (
              <a
                href="#projects"
                class="text-sm text-[var(--color-text-muted)] hover:text-text-light dark:hover:text-text-dark transition-colors"
              >
                Projects
              </a>
            )
          }
          {
            hasOpenSource && (
              <a
                href="#open-source"
                class="text-sm text-[var(--color-text-muted)] hover:text-text-light dark:hover:text-text-dark transition-colors"
              >
                Open Source
              </a>
            )
          }
          {
            hasExperience && (
              <a
                href="#experience"
                class="text-sm text-[var(--color-text-muted)] hover:text-text-light dark:hover:text-text-dark transition-colors"
              >
                Experience
              </a>
            )
          }
          {
            hasEducation && (
              <a
                href="#education"
                class="text-sm text-[var(--color-text-muted)] hover:text-text-light dark:hover:text-text-dark transition-colors"
              >
                Education
              </a>
            )
          }
        </nav>
        <p class="text-sm text-[var(--color-text-muted)]">
          © {new Date().getFullYear()}
          {siteConfig.name}. All rights reserved.
        </p>
      </div>
    </div>
  </div>

  <!-- Decorative pattern -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <svg
      aria-hidden="true"
      class="absolute bottom-0 left-0 w-full h-24 text-gray-100 dark:text-gray-800"
    >
      <pattern
        id="footer-pattern"
        x="0"
        y="0"
        width="100"
        height="100"
        patternUnits="userSpaceOnUse"
      >
        <path
          d="M0 50 Q 25 40, 50 50 T 100 50"
          stroke="currentColor"
          stroke-width="0.5"
          fill="none"
          opacity="0.4"></path>
      </pattern>
      <rect width="100%" height="100%" fill="url(#footer-pattern)"></rect>
    </svg>
  </div>
</footer>

<style define:vars={{ accentColor: siteConfig.accentColor }}>
  .accent-color {
    --accent-color: {{ accentColor }};
  }
</style>
