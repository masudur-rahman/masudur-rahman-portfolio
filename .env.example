# Server Configuration
# Port for the Astro development server (default: 4321)
PORT=4321

# Host address for the server (default: 0.0.0.0)
# Use 0.0.0.0 to allow external connections, localhost for local only
HOST=0.0.0.0

# Allowed hosts for the server (comma-separated list)
# Default: localhost,mrahman.xyz
# Examples:
# - For local development: localhost,127.0.0.1
# - For production: yourdomain.com,www.yourdomain.com
# - For Docker with custom domain: localhost,yourdomain.com,container-name
ALLOWED_HOSTS=localhost,mrahman.xyz

# Node Environment
NODE_ENV=production

# Docker-specific examples:
# PORT=8080
# HOST=0.0.0.0
# ALLOWED_HOSTS=localhost,yourdomain.com,container-name
